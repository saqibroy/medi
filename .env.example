# Local development defaults only. Do not copy these values into production.
APP_ENV=development
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/medical_annotations
TOKEN_SECRET=dev-token-secret-change-before-production
CSRF_SECRET=dev-csrf-secret-change-before-production
AUDIT_SIGNING_KEY=dev-audit-signing-key-change-before-production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080
SEED_DEMO_DATA=true
SESSION_TTL_MINUTES=480
LOGIN_RATE_LIMIT_PER_MINUTE=10
SENSITIVE_RATE_LIMIT_PER_MINUTE=60
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
SCAN_STORAGE_BACKEND=local
SCAN_STORAGE_ROOT=backend/data/sample_scan
SCAN_STORAGE_SIGNED_URL_TTL_SECONDS=300
DATA_DELETION_OPERATOR_ENABLED=false
# Production S3 values belong in the deployment secret/configuration manager:
# SCAN_STORAGE_BUCKET=medi-scans-prod
# SCAN_STORAGE_REGION=eu-central-1
# SCAN_STORAGE_SSE=aws:kms
# SCAN_STORAGE_KMS_KEY_ID=arn:aws:kms:region:account:key/example
# Production also requires SESSION_COOKIE_SECURE=true and an encrypted rediss://
# RATE_LIMIT_REDIS_URL. Keep production CSRF_SECRET distinct from TOKEN_SECRET.
